---
interface Props {
  title?: string;
  description?: string;
}

const {
  title = 'Savyasachi Jagadeeshan — Software Engineer',
  description = 'Software Engineer with 8 years of experience and a focus on Backend Engineering. Based in San Jose, CA.',
} = Astro.props;
---

<!doctype html>
<html lang="en" data-theme="dark">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <meta name="generator" content={Astro.generator} />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600&family=Syne:wght@600;700;800&display=swap"
      rel="stylesheet"
    />
    <link rel="stylesheet" href="/src/styles/global.css" />

    <style is:global>
      [data-theme="light"] {
        --color-bg: #f0f5fc;
        --color-surface: #ffffff;
        --color-text: #0f1a2e;
        --color-text-muted: #5a7090;
        --color-accent: #3b82c4;
        --color-accent-glow: rgba(59, 130, 196, 0.12);
        --color-border: #d0ddf0;
      }
    </style>

    <!-- Read localStorage before first paint to avoid flash -->
    <script is:inline>
      (function () {
        const stored = localStorage.getItem('theme');
        const preferred = window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
        document.documentElement.setAttribute('data-theme', stored || preferred);
      })();
    </script>
  </head>
  <body class="min-h-screen bg-[var(--color-bg)] text-[var(--color-text)] transition-colors duration-200">
    <slot />
  </body>
</html>
