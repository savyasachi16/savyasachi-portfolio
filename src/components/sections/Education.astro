---
import { education } from '../../data/education';
---

<section id="education" class="py-16 border-t border-[var(--color-border)]">
  <div class="max-w-6xl mx-auto px-6">
    <h2
      class="text-3xl font-semibold mb-10"
      style="color: var(--color-text);"
    >
      Education
    </h2>

    <div class="flex flex-col gap-8">
      {education.map((edu) => (
        <div class="relative pl-6 border-l-2" style="border-color: color-mix(in srgb, var(--color-accent) 30%, transparent);">
          <div
            class="absolute -left-1.5 top-1.5 w-2.5 h-2.5 rounded-full"
            style="background: var(--color-accent); box-shadow: 0 0 0 3px var(--color-bg);"
          />
          <p class="text-lg font-semibold" style="font-family: 'Syne', sans-serif; color: var(--color-text);">
            {edu.institution}
          </p>
          <p class="text-sm mb-1" style="color: var(--color-text-muted);">{edu.location}</p>
          <p class="text-sm font-medium" style="color: var(--color-text);">
            {edu.degree} &middot; {edu.field}
          </p>
          <p class="text-sm" style="color: var(--color-text-muted);">{edu.startDate} – {edu.endDate}</p>
        </div>
      ))}
    </div>
  </div>
</section>
