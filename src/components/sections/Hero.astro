---
import { config } from '../../data/config';
const { name, bio, social, titles } = config;
---

<section class="relative min-h-[calc(100vh-3.5rem)] flex items-center overflow-hidden">
  <div class="orb orb-a pointer-events-none absolute -top-32 -left-32 w-[500px] h-[500px] rounded-full"></div>
  <div class="orb orb-b pointer-events-none absolute -bottom-32 -right-16 w-[400px] h-[400px] rounded-full"></div>

  <div class="relative z-10 max-w-6xl mx-auto px-6 py-16 w-full">
    <div class="flex flex-col sm:flex-row sm:items-start gap-4 sm:gap-6 md:gap-8 mb-8">
      <img
        src="/avatar.jpg"
        alt={`${name.first} ${name.last}`}
        width="96"
        height="96"
        class="hero-avatar shrink-0 rounded-full object-cover"
      />
      <div class="min-w-0 w-full">
        <p class="text-sm font-medium mb-2 tracking-widest uppercase" style="color: var(--color-accent);">
          Hello, I'm
        </p>
        <h1
          class="text-[clamp(2.5rem,10vw,4.5rem)] md:text-7xl font-bold tracking-tight leading-[1.05]"
          style="font-family: 'Syne', sans-serif; color: var(--color-text);"
        >
          <span id="hero-name-text" data-first={name.first} data-last={name.last}>{name.first}<br />{name.last}</span><span id="hero-cursor" class="hero-cursor" aria-hidden="true">|</span>
        </h1>
        <p class="text-lg mt-2" style="color: var(--color-text-muted); font-family: 'Syne', sans-serif;">but everyone calls me {name.nickname}</p>
      </div>
    </div>

    <div class="flex flex-wrap items-center gap-2 mb-6">
      {titles.map((t) => (
        <span class="role-pill inline-flex items-center px-3 py-1 rounded-full border text-sm">{t}</span>
      ))}
    </div>

    <p class="text-base max-w-xl leading-relaxed mb-10" style="color: var(--color-text-muted);">
      {bio}
    </p>

    <div class="flex flex-wrap gap-4 mb-12">
      <a
        href="#experience"
        class="hero-cta-primary inline-flex items-center gap-2 px-5 py-2.5 rounded-lg text-sm font-medium"
      >
        View my work
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><path d="M5 12h14"/><path d="m12 5 7 7-7 7"/></svg>
      </a>
      <a
        href="/resume.pdf"
        target="_blank"
        rel="noopener noreferrer"
        class="hero-cta-secondary inline-flex items-center gap-2 px-5 py-2.5 rounded-lg border text-sm font-medium"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        Download Resume
      </a>
    </div>

    <div class="flex items-center gap-5">
      {social.github && (
        <a href={social.github} target="_blank" rel="noopener noreferrer" class="hero-social inline-flex items-center gap-2 text-sm" aria-label="GitHub">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M12 .5C5.73.5.5 5.73.5 12a11.5 11.5 0 0 0 7.86 10.92c.57.1.78-.25.78-.55v-2.02c-3.2.7-3.87-1.38-3.87-1.38-.52-1.33-1.27-1.68-1.27-1.68-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.02 1.75 2.68 1.24 3.34.95.1-.74.4-1.24.73-1.53-2.56-.29-5.25-1.28-5.25-5.69 0-1.26.45-2.28 1.18-3.08-.12-.29-.51-1.46.11-3.04 0 0 .96-.31 3.15 1.17a10.96 10.96 0 0 1 5.73 0c2.18-1.48 3.14-1.17 3.14-1.17.63 1.58.23 2.75.11 3.04.73.8 1.18 1.82 1.18 3.08 0 4.42-2.69 5.39-5.26 5.68.41.35.78 1.05.78 2.12v3.14c0 .3.2.66.79.55A11.5 11.5 0 0 0 23.5 12C23.5 5.73 18.27.5 12 .5Z"/></svg>
          GitHub
        </a>
      )}
      {social.linkedin && (
        <a href={social.linkedin} target="_blank" rel="noopener noreferrer" class="hero-social inline-flex items-center gap-2 text-sm" aria-label="LinkedIn">
          <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="currentColor"><path d="M20.45 20.45h-3.56v-5.57c0-1.33-.02-3.04-1.85-3.04-1.86 0-2.15 1.45-2.15 2.95v5.66H9.33V9h3.41v1.56h.05a3.74 3.74 0 0 1 3.37-1.85c3.6 0 4.27 2.37 4.27 5.46v6.28ZM5.34 7.43a2.06 2.06 0 1 1 0-4.12 2.06 2.06 0 0 1 0 4.12ZM7.12 20.45H3.56V9h3.56v11.45ZM22.23 0H1.77C.79 0 0 .77 0 1.72v20.56C0 23.23.79 24 1.77 24h20.46c.98 0 1.77-.77 1.77-1.72V1.72C24 .77 23.21 0 22.23 0Z"/></svg>
          LinkedIn
        </a>
      )}
    </div>
  </div>
</section>

<style>
  .hero-avatar {
    border: 2px solid var(--color-border);
    box-shadow: 0 8px 32px var(--color-accent-glow);
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .hero-avatar:hover {
    border-color: var(--color-accent);
    box-shadow: 0 8px 40px var(--color-accent-glow);
  }
  @media (max-width: 640px) {
    .hero-avatar { width: 80px; height: 80px; }
  }

  .role-pill {
    border-color: var(--color-border);
    color: var(--color-text-muted);
    background: color-mix(in srgb, var(--color-accent-glow) 40%, transparent);
    transition: border-color 0.15s, color 0.15s;
  }
  .role-pill:hover {
    border-color: var(--color-accent);
    color: var(--color-text);
  }

  .orb {
    background: var(--color-accent-glow);
    filter: blur(80px);
  }
  @media (prefers-reduced-motion: no-preference) {
    .orb-a { animation: orb-pulse 8s ease-in-out infinite; }
    .orb-b { animation: orb-pulse 8s ease-in-out infinite; animation-delay: 4s; }
  }
  .hero-cursor {
    display: inline-block;
    margin-left: 2px;
    color: var(--color-accent);
  }
  @media (prefers-reduced-motion: no-preference) {
    .hero-cursor { animation: blink 1s step-start infinite; }
  }
  @media (prefers-reduced-motion: reduce) {
    #hero-cursor { display: none; }
  }
  @keyframes blink {
    0%, 100% { opacity: 1; }
    50%       { opacity: 0; }
  }
  .hero-cta-primary {
    background: var(--color-accent);
    color: var(--color-bg);
    transition: opacity 0.15s, transform 0.15s;
  }
  .hero-cta-primary:hover { opacity: 0.9; transform: translateY(-1px); }
  .hero-cta-secondary {
    border-color: var(--color-border);
    color: var(--color-text-muted);
    transition: color 0.15s, border-color 0.15s, transform 0.15s;
  }
  .hero-cta-secondary:hover {
    border-color: var(--color-accent);
    color: var(--color-text);
    transform: translateY(-1px);
  }
  .hero-social {
    color: var(--color-text-muted);
    transition: color 0.15s;
  }
  .hero-social:hover { color: var(--color-text); }
</style>

<script>
  const prefersReduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
  if (!prefersReduced) {
    const nameEl = document.getElementById('hero-name-text') as HTMLElement;
    const part1 = nameEl.dataset.first ?? '';
    const part2 = nameEl.dataset.last ?? '';
    const speed = 80;

    function sleep(ms: number) {
      return new Promise(r => setTimeout(r, ms));
    }

    async function typeHero() {
      nameEl.innerHTML = '';
      for (let i = 0; i <= part1.length; i++) {
        nameEl.innerHTML = part1.slice(0, i);
        await sleep(speed);
      }
      nameEl.innerHTML = part1 + '<br>';
      for (let i = 0; i <= part2.length; i++) {
        nameEl.innerHTML = part1 + '<br>' + part2.slice(0, i);
        await sleep(speed);
      }
    }

    typeHero();
  }
</script>
