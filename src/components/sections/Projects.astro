---
import { projects } from '../../data/projects';
import { config } from '../../data/config';
import ProjectCard from '../ui/ProjectCard.astro';
---

<section id="projects" class="py-16 border-t border-[var(--color-border)]">
  <div class="max-w-6xl mx-auto px-6">
    <h2 class="text-3xl font-semibold text-[var(--color-text)] mb-10">Projects</h2>
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4">
      {projects.map((project) => (
        <ProjectCard project={project} />
      ))}
    </div>
    {config.social.github && (
      <p class="mt-8 text-sm">
        <a
          href={config.social.github}
          target="_blank"
          rel="noopener noreferrer"
          class="projects-more-link"
        >
          More on GitHub ↗
        </a>
      </p>
    )}
  </div>
</section>

<style>
  .projects-more-link {
    color: var(--color-text-muted);
    transition: color 0.15s;
  }
  .projects-more-link:hover { color: var(--color-accent); }
</style>
