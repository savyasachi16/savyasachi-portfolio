---
import { config } from '../../data/config';

interface Book {
  title: string;
  author: string;
  cover: string;
  rating: number;
  link: string;
}

function parseRSS(xml: string): Book[] {
  const items = xml.match(/<item>([\s\S]*?)<\/item>/g) ?? [];
  return items.map((item) => {
    const tag = (name: string) => {
      const m =
        item.match(new RegExp(`<${name}[^>]*><!\\[CDATA\\[([\\s\\S]*?)\\]\\]><\\/${name}>`)) ??
        item.match(new RegExp(`<${name}[^>]*>([\\s\\S]*?)<\\/${name}>`));
      return (m?.[1] ?? '').trim();
    };
    const cover = tag('book_image_url').replace(/_S[XY]\d+_/, '_SX98_');
    return {
      title: tag('title'),
      author: tag('author_name'),
      cover,
      rating: parseInt(tag('user_rating')) || 0,
      link: item.match(/<link>([\s\S]*?)<\/link>/)?.[1]?.trim() ?? '',
    };
  });
}

async function fetchShelf(shelf: string, limit = 8): Promise<Book[]> {
  try {
    const res = await fetch(
      `https://www.goodreads.com/review/list_rss/${config.goodreadsUserId}?shelf=${shelf}&sort=date_read&per_page=${limit}`
    );
    const xml = await res.text();
    return parseRSS(xml).slice(0, limit);
  } catch {
    return [];
  }
}

const currentlyReading = await fetchShelf('currently-reading', 4);
const recentlyRead = await fetchShelf('read', 8);

const stars = (n: number) => '★'.repeat(n) + '☆'.repeat(5 - n);
---

<section id="beyond" class="py-16 border-t border-[var(--color-border)]">
  <div class="max-w-6xl mx-auto px-6">
    <h2
      class="text-3xl font-semibold mb-2"
      style="color: var(--color-text);"
    >
      Beyond the IDE
    </h2>
    <p class="text-sm mb-8" style="color: var(--color-text-muted);">What I do when I'm not staring at a terminal.</p>

    <!-- Interests -->
    <div class="mb-8">
      <h3 class="text-xs font-semibold uppercase tracking-widest mb-6" style="color: var(--color-text-muted);">Interests</h3>
      <div class="flex flex-wrap gap-2">
        {[
          { label: 'Reading',       icon: '📚' },
          { label: 'Skiing',        icon: '⛷️' },
          { label: 'Motorcycling',  icon: '🏍️' },
          { label: 'Petrolhead',    icon: '🚗' },
          { label: 'F1',            icon: '🏎️' },
          { label: 'Running',       icon: '🏃' },
          { label: 'Kettlebells',   icon: '🏋️' },
        ].map(({ label, icon }) => (
          <span
            class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border text-sm transition-all duration-150"
            style="border-color: var(--color-border); color: var(--color-text-muted); background: color-mix(in srgb, var(--color-accent-glow) 40%, transparent);"
          >
            <span>{icon}</span>{label}
          </span>
        ))}
      </div>
    </div>

    <!-- Spotify -->
    <div class="mb-8">
      <h3 class="text-xs font-semibold uppercase tracking-widest mb-6" style="color: var(--color-text-muted);">
        Spotify
      </h3>
      <div id="spotify-card" class="flex items-center gap-4 p-4 rounded-xl border backdrop-blur-sm w-full max-w-sm" style="border-color: var(--color-border); background: color-mix(in srgb, var(--color-surface) 70%, transparent);">
        <!-- skeleton -->
        <div class="w-14 h-14 rounded-md shrink-0 animate-pulse" style="background: var(--color-border);"></div>
        <div class="flex flex-col gap-2 flex-1">
          <div class="h-3 rounded animate-pulse w-3/4" style="background: var(--color-border);"></div>
          <div class="h-2.5 rounded animate-pulse w-1/2" style="background: var(--color-border);"></div>
        </div>
      </div>
    </div>

    <!-- Currently Reading -->
    {currentlyReading.length > 0 && (
      <div class="mb-8">
        <h3 class="text-xs font-semibold uppercase tracking-widest mb-6" style="color: var(--color-text-muted);">
          Currently Reading
        </h3>
        <div class="flex flex-wrap gap-4">
          {currentlyReading.map((book) => (
            <a
              href={book.link}
              target="_blank"
              rel="noopener noreferrer"
              class="flex gap-4 p-4 rounded-xl border backdrop-blur-sm transition-all duration-200 w-full max-w-sm"
              style="border-color: var(--color-border); background: color-mix(in srgb, var(--color-surface) 70%, transparent);"
              onmouseenter="this.style.borderColor='var(--color-accent)'; this.style.boxShadow='0 4px 24px var(--color-accent-glow)'"
              onmouseleave="this.style.borderColor='var(--color-border)'; this.style.boxShadow='none'"
            >
              {book.cover && (
                <img
                  src={book.cover}
                  alt={book.title}
                  width="64"
                  height="98"
                  class="rounded object-cover shrink-0"
                  style="box-shadow: 0 2px 8px rgba(0,0,0,0.4);"
                />
              )}
              <div class="flex flex-col justify-center gap-1 min-w-0">
                <span class="text-sm font-medium leading-snug" style="color: var(--color-text);">{book.title}</span>
                <span class="text-xs" style="color: var(--color-text-muted);">{book.author}</span>
                <span class="text-xs mt-1" style="color: var(--color-accent);">reading now</span>
              </div>
            </a>
          ))}
        </div>
      </div>
    )}

    <!-- Recently Read -->
    {recentlyRead.length > 0 && (
      <div>
        <h3 class="text-xs font-semibold uppercase tracking-widest mb-6" style="color: var(--color-text-muted);">
          Recently Read
        </h3>
        <div class="grid grid-cols-2 sm:grid-cols-4 lg:grid-cols-8 gap-3">
          {recentlyRead.map((book) => (
            <a
              href={book.link}
              target="_blank"
              rel="noopener noreferrer"
              class="group flex flex-col gap-2 transition-transform duration-150 hover:-translate-y-1"
              title={`${book.title} — ${book.author}`}
            >
              {book.cover ? (
                <img
                  src={book.cover}
                  alt={book.title}
                  width="98"
                  height="148"
                  class="rounded-md w-full object-cover"
                  style="box-shadow: 0 2px 8px rgba(0,0,0,0.4); aspect-ratio: 2/3;"
                />
              ) : (
                <div
                  class="rounded-md w-full flex items-center justify-center text-xs text-center p-2"
                  style="aspect-ratio: 2/3; background: var(--color-surface); color: var(--color-text-muted); border: 1px solid var(--color-border);"
                >
                  {book.title}
                </div>
              )}
              {book.rating > 0 && (
                <span class="text-[10px] tracking-tight" style="color: var(--color-accent);">
                  {stars(book.rating)}
                </span>
              )}
            </a>
          ))}
        </div>
      </div>
    )}
  </div>
</section>

<script>
  async function loadSpotify() {
    const card = document.getElementById('spotify-card');
    if (!card) return;

    try {
      const res = await fetch('/api/spotify');
      const data = await res.json();

      if (!data.title) {
        card.innerHTML = `<span style="font-size:0.8rem; color: var(--color-text-muted);">Nothing playing right now.</span>`;
        return;
      }

      const playing = data.isPlaying;
      const dot = playing
        ? `<span style="display:inline-block;width:7px;height:7px;border-radius:50%;background:#1db954;animation:spotify-pulse 1.5s ease-in-out infinite;"></span>`
        : '';

      card.outerHTML = `
        <a href="${data.songUrl}" target="_blank" rel="noopener noreferrer"
           id="spotify-card"
           style="display:flex;align-items:center;gap:1rem;padding:1rem;border-radius:0.75rem;border:1px solid var(--color-border);backdrop-filter:blur(4px);background:color-mix(in srgb, var(--color-surface) 70%, transparent);text-decoration:none;transition:border-color .2s,box-shadow .2s;width:100%;max-width:24rem;box-sizing:border-box;"
           onmouseenter="this.style.borderColor='var(--color-accent)';this.style.boxShadow='0 4px 24px var(--color-accent-glow)'"
           onmouseleave="this.style.borderColor='var(--color-border)';this.style.boxShadow='none'"
        >
          <img src="${data.albumArt}" alt="${data.album}" width="56" height="56"
               style="border-radius:6px;object-fit:cover;flex-shrink:0;box-shadow:0 2px 8px rgba(0,0,0,0.4);" />
          <div style="display:flex;flex-direction:column;gap:3px;min-width:0;">
            <span style="display:flex;align-items:center;gap:6px;font-size:0.875rem;font-weight:500;color:var(--color-text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">
              ${dot} ${data.title}
            </span>
            <span style="font-size:0.75rem;color:var(--color-text-muted);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${data.artist}</span>
            <span style="font-size:0.7rem;color:var(--color-text-muted);opacity:0.7;">${playing ? 'Listening now' : 'Last played'}</span>
          </div>
        </a>
      `;
    } catch {
      const card2 = document.getElementById('spotify-card');
      if (card2) card2.innerHTML = `<span style="font-size:0.8rem;color:var(--color-text-muted);">Couldn't load Spotify.</span>`;
    }
  }

  loadSpotify();
</script>

<style is:global>
  @keyframes spotify-pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%       { opacity: 0.5; transform: scale(0.85); }
  }
</style>
