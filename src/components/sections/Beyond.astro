---
import SectionHeading from '../ui/SectionHeading.astro';
---

<section id="beyond" class="py-16 border-t border-[var(--color-border)]">
  <div class="max-w-6xl mx-auto px-6">
    <SectionHeading num="05" title="Beyond the IDE" subtitle="What I do when I'm not staring at a terminal." />

    <div class="mb-8">
      <h3 class="text-xs font-semibold uppercase tracking-widest mb-6" style="color: var(--color-text-muted);">Interests</h3>
      <div class="flex flex-wrap gap-2">
        {[
          { label: 'Reading',       icon: '📚' },
          { label: 'Skiing',        icon: '⛷️' },
          { label: 'Motorcycling',  icon: '🏍️' },
          { label: 'Petrolhead',    icon: '🚗' },
          { label: 'F1',            icon: '🏎️' },
          { label: 'Running',       icon: '🏃' },
          { label: 'Kettlebells',   icon: '🏋️' },
        ].map(({ label, icon }) => (
          <span
            class="inline-flex items-center gap-2 px-4 py-1.5 rounded-full border text-sm"
            style="border-color: var(--color-border); color: var(--color-text-muted); background: color-mix(in srgb, var(--color-accent-glow) 40%, transparent);"
          >
            <span>{icon}</span>{label}
          </span>
        ))}
      </div>
    </div>

    <div class="mb-8">
      <h3 class="text-xs font-semibold uppercase tracking-widest mb-6" style="color: var(--color-text-muted);">
        Spotify
      </h3>
      <div class="flex flex-col sm:flex-row gap-4 items-start">
        <div id="spotify-card" class="flex items-center gap-4 p-4 rounded-xl border backdrop-blur-sm shrink-0" style="border-color: var(--color-border); background: color-mix(in srgb, var(--color-surface) 70%, transparent); width: 100%; max-width: 20rem;">
          <div class="w-14 h-14 rounded-md shrink-0 animate-pulse" style="background: var(--color-border);"></div>
          <div class="flex flex-col gap-2 flex-1">
            <div class="h-3 rounded animate-pulse w-3/4" style="background: var(--color-border);"></div>
            <div class="h-2.5 rounded animate-pulse w-1/2" style="background: var(--color-border);"></div>
          </div>
        </div>
        <div class="flex flex-col flex-1">
          <span class="text-xs font-semibold uppercase tracking-widest mb-3" style="color: var(--color-text-muted);">Top Tracks — All Time</span>
          <div id="top-tracks" class="flex flex-col justify-center">
            {Array.from({ length: 5 }).map(() => (
              <div class="flex items-center gap-3 px-3 py-2 rounded-lg">
                <div class="w-8 h-8 rounded shrink-0 animate-pulse" style="background: var(--color-border);"></div>
                <div class="flex flex-col gap-1.5 flex-1">
                  <div class="h-2.5 rounded animate-pulse w-2/3" style="background: var(--color-border);"></div>
                  <div class="h-2 rounded animate-pulse w-1/3" style="background: var(--color-border);"></div>
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>

    <div id="currently-reading-block" class="mb-8 hidden">
      <h3 class="text-xs font-semibold uppercase tracking-widest mb-6" style="color: var(--color-text-muted);">
        Currently Reading
      </h3>
      <div id="currently-reading" class="flex flex-wrap gap-4"></div>
    </div>

    <div id="recently-read-block" class="hidden">
      <h3 class="text-xs font-semibold uppercase tracking-widest mb-6" style="color: var(--color-text-muted);">
        Recently Read
      </h3>
      <div id="recently-read" class="grid grid-cols-2 sm:grid-cols-4 lg:grid-cols-8 gap-3"></div>
    </div>
  </div>
</section>

<style is:global>
  .spotify-card-link {
    display: flex;
    align-items: center;
    gap: 1rem;
    padding: 1rem;
    border-radius: 0.75rem;
    border: 1px solid var(--color-border);
    backdrop-filter: blur(4px);
    background: color-mix(in srgb, var(--color-surface) 70%, transparent);
    text-decoration: none;
    transition: border-color 0.2s, box-shadow 0.2s;
    max-width: 20rem;
    box-sizing: border-box;
  }
  .spotify-card-link:hover {
    border-color: var(--color-accent);
    box-shadow: 0 4px 24px var(--color-accent-glow);
  }
  .top-track-row {
    display: flex;
    align-items: center;
    gap: 0.75rem;
    padding: 0.625rem 0.75rem;
    border-radius: 0.5rem;
    text-decoration: none;
    transition: background 0.15s;
  }
  .top-track-row:hover {
    background: color-mix(in srgb, var(--color-accent-glow) 60%, transparent);
  }
  .book-card {
    display: flex;
    gap: 1rem;
    padding: 1rem;
    border-radius: 0.75rem;
    border: 1px solid var(--color-border);
    backdrop-filter: blur(4px);
    background: color-mix(in srgb, var(--color-surface) 70%, transparent);
    width: 100%;
    max-width: 24rem;
    transition: border-color 0.2s, box-shadow 0.2s;
  }
  .book-card:hover {
    border-color: var(--color-accent);
    box-shadow: 0 4px 24px var(--color-accent-glow);
  }
  .book-tile {
    display: flex;
    flex-direction: column;
    gap: 0.5rem;
    transition: transform 0.15s;
    position: relative;
  }
  .book-tile:hover { transform: translateY(-4px); }
  .book-rating {
    position: absolute;
    top: 0.35rem;
    right: 0.35rem;
    padding: 0.125rem 0.375rem;
    border-radius: 0.25rem;
    background: rgba(12, 15, 20, 0.85);
    color: var(--color-accent);
    font-size: 0.65rem;
    letter-spacing: 0.02em;
    line-height: 1;
    backdrop-filter: blur(4px);
  }

  .spotify-dot {
    display: inline-block;
    width: 7px;
    height: 7px;
    border-radius: 50%;
    background: #1db954;
  }
  @media (prefers-reduced-motion: no-preference) {
    .spotify-dot {
      animation: spotify-pulse 1.5s ease-in-out infinite;
    }
  }
  @keyframes spotify-pulse {
    0%, 100% { opacity: 1; transform: scale(1); }
    50%       { opacity: 0.5; transform: scale(0.85); }
  }
</style>

<script>
  function esc(s: string) {
    return s.replace(/[&<>"']/g, (c) => ({
      '&': '&amp;', '<': '&lt;', '>': '&gt;', '"': '&quot;', "'": '&#39;',
    }[c]!));
  }

  async function loadSpotify() {
    const card = document.getElementById('spotify-card');
    if (!card) return;

    try {
      const res = await fetch('/api/spotify');
      const data = await res.json();

      if (!data.title) {
        card.innerHTML = `<span style="font-size:0.8rem; color: var(--color-text-muted);">Nothing playing right now.</span>`;
        return;
      }

      const playing = data.isPlaying;
      const dot = playing ? `<span class="spotify-dot"></span>` : '';

      card.outerHTML = `
        <a href="${esc(data.songUrl)}" target="_blank" rel="noopener noreferrer"
           id="spotify-card" class="spotify-card-link"
        >
          <img src="${esc(data.albumArt)}" alt="${esc(data.album)}" width="56" height="56"
               style="border-radius:6px;object-fit:cover;flex-shrink:0;box-shadow:0 2px 8px rgba(0,0,0,0.4);" />
          <div style="display:flex;flex-direction:column;gap:3px;min-width:0;">
            <span style="display:flex;align-items:center;gap:6px;font-size:0.875rem;font-weight:500;color:var(--color-text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">
              ${dot} ${esc(data.title)}
            </span>
            <span style="font-size:0.75rem;color:var(--color-text-muted);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${esc(data.artist)}</span>
            <span style="font-size:0.7rem;color:var(--color-text-muted);opacity:0.7;">${playing ? 'Listening now' : 'Last played'}</span>
          </div>
        </a>
      `;
    } catch {
      const card2 = document.getElementById('spotify-card');
      if (card2) card2.innerHTML = `<span style="font-size:0.8rem;color:var(--color-text-muted);">Couldn't load Spotify.</span>`;
    }
  }

  async function loadTopTracks() {
    const container = document.getElementById('top-tracks');
    if (!container) return;

    try {
      const res = await fetch('/api/spotify-top');
      const tracks = await res.json();

      if (!tracks.length) {
        container.innerHTML = `<span style="font-size:0.8rem;color:var(--color-text-muted);">No top tracks found.</span>`;
        return;
      }

      container.innerHTML = tracks.map((t: any, i: number) => `
        <a href="${esc(t.songUrl)}" target="_blank" rel="noopener noreferrer" class="top-track-row">
          <span style="font-size:0.7rem;width:1.25rem;text-align:right;color:var(--color-text-muted);flex-shrink:0;">${i + 1}</span>
          <img src="${esc(t.albumArt)}" alt="${esc(t.album)}" width="40" height="40"
               style="border-radius:4px;object-fit:cover;flex-shrink:0;box-shadow:0 1px 4px rgba(0,0,0,0.4);" />
          <div style="display:flex;flex-direction:column;gap:2px;min-width:0;">
            <span style="font-size:0.875rem;font-weight:500;color:var(--color-text);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${esc(t.title)}</span>
            <span style="font-size:0.75rem;color:var(--color-text-muted);white-space:nowrap;overflow:hidden;text-overflow:ellipsis;">${esc(t.artist)}</span>
          </div>
        </a>
      `).join('');
    } catch {
      const el = document.getElementById('top-tracks');
      if (el) el.innerHTML = `<span style="font-size:0.8rem;color:var(--color-text-muted);">Couldn't load top tracks.</span>`;
    }
  }

  function stars(n: number) {
    return '★'.repeat(n) + '☆'.repeat(5 - n);
  }

  async function loadGoodreads() {
    const currentBlock = document.getElementById('currently-reading-block');
    const currentList  = document.getElementById('currently-reading');
    const readBlock    = document.getElementById('recently-read-block');
    const readList     = document.getElementById('recently-read');
    if (!currentBlock || !currentList || !readBlock || !readList) return;

    try {
      const res = await fetch('/api/goodreads');
      const { currentlyReading, recentlyRead } = await res.json();

      if (currentlyReading?.length) {
        currentList.innerHTML = currentlyReading.map((book: any) => `
          <a href="${esc(book.link)}" target="_blank" rel="noopener noreferrer" class="book-card">
            ${book.cover ? `<img src="${esc(book.cover)}" alt="${esc(book.title)}" width="64" height="98" class="rounded object-cover shrink-0" style="box-shadow:0 2px 8px rgba(0,0,0,0.4);" />` : ''}
            <div class="flex flex-col justify-center gap-1 min-w-0">
              <span class="text-sm font-medium leading-snug" style="color: var(--color-text);">${esc(book.title)}</span>
              <span class="text-xs" style="color: var(--color-text-muted);">${esc(book.author)}</span>
              <span class="text-xs mt-1" style="color: var(--color-accent);">reading now</span>
            </div>
          </a>
        `).join('');
        currentBlock.classList.remove('hidden');
      }

      if (recentlyRead?.length) {
        readList.innerHTML = recentlyRead.map((book: any) => `
          <a href="${esc(book.link)}" target="_blank" rel="noopener noreferrer" class="book-tile" title="${esc(book.title)} — ${esc(book.author)}">
            ${book.cover
              ? `<img src="${esc(book.cover)}" alt="${esc(book.title)}" width="98" height="148" class="rounded-md w-full object-cover" style="box-shadow:0 2px 8px rgba(0,0,0,0.4); aspect-ratio: 2/3;" />`
              : `<div class="rounded-md w-full flex items-center justify-center text-xs text-center p-2" style="aspect-ratio: 2/3; background: var(--color-surface); color: var(--color-text-muted); border: 1px solid var(--color-border);">${esc(book.title)}</div>`}
            ${book.rating > 0 ? `<span class="book-rating">${stars(book.rating)}</span>` : ''}
          </a>
        `).join('');
        readBlock.classList.remove('hidden');
      }
    } catch {
      // keep blocks hidden on error
    }
  }

  loadSpotify();
  loadTopTracks();
  loadGoodreads();
</script>
