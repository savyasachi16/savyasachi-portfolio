---
import { config } from '../data/config';
const fullName = `${config.name.first} ${config.name.last}`;

const links = [
  config.social.github   && { label: 'GitHub',   href: config.social.github },
  config.social.linkedin && { label: 'LinkedIn',  href: config.social.linkedin },
  config.social.email    && { label: 'Email',     href: `mailto:${config.social.email}` },
  { label: 'Resume', href: '/resume.pdf' },
].filter(Boolean) as { label: string; href: string }[];

const kofi = { id: 'kofi', label: 'Ko-fi', url: 'https://ko-fi.com/savyasachi', color: '#FF5E5B' };

const wallets = [
  { id: 'btc', label: 'BTC', address: 'bc1qc0fv4mactnhkpddhn3h7y63ktzemaetw6pa5fe',  color: '#F7931A' },
  { id: 'eth', label: 'ETH', address: '0xe73B6A122E9B41d8a6c979AEBD109f23A85D01f8',   color: '#627EEA' },
  { id: 'ltc', label: 'LTC', address: 'ltc1qng7ax8m8aq0z4dms5z5vxwldyl4wk666xpfj0e', color: '#345D9D' },
];
---

<footer class="border-t border-[var(--color-border)] py-8">
  <div class="max-w-6xl mx-auto px-6 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm" style="color: var(--color-text-muted);">
    <span>&copy; {new Date().getFullYear()} {fullName}</span>
    <div class="flex items-center gap-5 flex-wrap justify-center">
      {links.map((link) => (
        <>
          <a
            href={link.href}
            target={link.href.startsWith('mailto') || link.href.startsWith('/') ? undefined : '_blank'}
            rel={link.href.startsWith('http') ? 'noopener noreferrer' : undefined}
            class="transition-all hover:text-[var(--color-accent)]"
            style="color: var(--color-text-muted);"
          >
            {link.label}
          </a>
          <span style="color: var(--color-border);">·</span>
        </>
      ))}

      <!-- Tip Jar -->
      <div>
        <button
          id="tip-jar-btn"
          class="transition-all hover:text-[var(--color-accent)]"
          style="color: var(--color-text-muted); background: none; border: none; cursor: pointer; font-size: inherit; padding: 0; font-family: inherit;"
        >
          Tip Jar
        </button>

        <!-- Popover -->
        <div
          id="tip-popover"
          class="hidden p-4 rounded-xl border z-50"
          style="position: fixed; background: var(--color-surface); border-color: var(--color-border); width: 18rem; box-shadow: 0 8px 32px rgba(0,0,0,0.4);"
        >
          <p class="text-xs mb-4 leading-relaxed" style="color: var(--color-text-muted);">
            If you found this useful, or just vibing with the stack,
            consider supporting me!
          </p>

          <!-- Ko-fi button -->
          <button
            class="tip-trigger w-full py-2 px-3 mb-4 rounded-lg text-sm font-semibold border transition-all flex items-center justify-center gap-2"
            style={`border-color: var(--color-border); color: var(--color-text-muted); background: none; cursor: pointer; font-family: inherit;`}
            onmouseenter={`this.style.borderColor='${kofi.color}';this.style.color='${kofi.color}';this.style.background='${kofi.color}18';`}
            onmouseleave="this.style.borderColor='var(--color-border)';this.style.color='var(--color-text-muted)';this.style.background='none';"
            data-id={kofi.id}
          >
            ☕ {kofi.label}
          </button>

          <!-- Divider -->
          <div class="flex items-center gap-3 my-4">
            <div style="flex: 1; height: 1px; background: var(--color-border);"></div>
            <span class="text-xs" style="color: var(--color-text-muted);">or crypto</span>
            <div style="flex: 1; height: 1px; background: var(--color-border);"></div>
          </div>

          <!-- Crypto buttons -->
          <div class="flex gap-2">
            {wallets.map((w) => (
              <button
                class="tip-trigger flex-1 py-1.5 rounded-lg text-xs font-semibold border transition-all"
                style={`border-color: var(--color-border); color: var(--color-text-muted); background: none; cursor: pointer; font-family: inherit;`}
                onmouseenter={`this.style.borderColor='${w.color}';this.style.color='${w.color}';this.style.background='${w.color}18';`}
                onmouseleave="this.style.borderColor='var(--color-border)';this.style.color='var(--color-text-muted)';this.style.background='none';"
                data-id={w.id}
              >
                {w.label}
              </button>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</footer>

<!-- Ko-fi Modal -->
<div
  id={`modal-${kofi.id}`}
  class="tip-modal"
  style="display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; z-index: 50; align-items: center; justify-content: center; padding: 1rem; background: rgba(0,0,0,0.6); backdrop-filter: blur(4px);"
>
  <div
    class="relative rounded-2xl border p-6 flex flex-col items-center gap-4 w-full"
    style="background: var(--color-surface); border-color: var(--color-border); box-shadow: 0 24px 64px rgba(0,0,0,0.5); max-width: 28rem;"
  >
    <button
      class="modal-close absolute top-4 right-4 transition-colors hover:text-[var(--color-text)]"
      style="color: var(--color-text-muted); background: none; border: none; cursor: pointer; font-size: 1.1rem; line-height: 1;"
    >
      ✕
    </button>

    <span
      class="text-xs font-bold rounded-md px-3 py-1"
      style={`background:${kofi.color};color:#fff;letter-spacing:0.08em;`}
    >
      {kofi.label}
    </span>

    <img
      src={`https://api.qrserver.com/v1/create-qr-code/?size=180x180&data=${kofi.url}&bgcolor=ffffff&color=000000&margin=8&ecc=H`}
      alt={`${kofi.label} QR code`}
      width="180"
      height="180"
      class="rounded-lg"
    />

    <div class="w-full flex flex-col gap-2">
      <code class="w-full block text-xs text-center break-all" style="color: var(--color-text-muted);">{kofi.url}</code>
      <button
        class="open-kofi w-full py-2 rounded-lg text-sm font-medium transition-opacity hover:opacity-80"
        style="background: var(--color-accent); color: var(--color-bg);"
      >
        Open Ko-fi →
      </button>
    </div>
  </div>
</div>

<!-- Crypto Modals -->
{wallets.map((w) => (
  <div
    id={`modal-${w.id}`}
    class="tip-modal"
    style="display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; z-index: 50; align-items: center; justify-content: center; padding: 1rem; background: rgba(0,0,0,0.6); backdrop-filter: blur(4px);"
  >
    <div
      class="relative rounded-2xl border p-6 flex flex-col items-center gap-4 w-full"
      style="background: var(--color-surface); border-color: var(--color-border); box-shadow: 0 24px 64px rgba(0,0,0,0.5); max-width: 28rem;"
    >
      <button
        class="modal-close absolute top-4 right-4 transition-colors hover:text-[var(--color-text)]"
        style="color: var(--color-text-muted); background: none; border: none; cursor: pointer; font-size: 1.1rem; line-height: 1;"
      >
        ✕
      </button>

      <span
        class="text-xs font-bold rounded-md px-3 py-1"
        style={`background:${w.color};color:#fff;letter-spacing:0.08em;`}
      >
        {w.label}
      </span>

      <img
        src={`https://api.qrserver.com/v1/create-qr-code/?size=180x180&data=${w.address}&bgcolor=ffffff&color=000000&margin=8&ecc=H`}
        alt={`${w.label} QR code`}
        width="180"
        height="180"
        class="rounded-lg"
      />

      <div class="w-full flex flex-col gap-2">
        <code class="w-full block text-xs text-center break-all" style="color: var(--color-text-muted);">{w.address}</code>
        <button
          class="copy-addr w-full py-2 rounded-lg text-sm font-medium transition-opacity hover:opacity-80"
          style="background: var(--color-accent); color: var(--color-bg);"
          data-address={w.address}
        >
          Copy address
        </button>
      </div>
    </div>
  </div>
))}

<script>
  const tipBtn = document.getElementById('tip-jar-btn');
  const popover = document.getElementById('tip-popover');

  tipBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    const isHidden = popover?.classList.contains('hidden');
    if (isHidden && popover && tipBtn) {
      const rect = (tipBtn as HTMLElement).getBoundingClientRect();
      const pw = 256; // 16rem
      const margin = 8;
      // Position above the button, right-aligned to it
      let left = rect.right - pw;
      // Clamp so it never goes off either edge
      left = Math.max(margin, Math.min(left, window.innerWidth - pw - margin));
      popover.style.bottom = (window.innerHeight - rect.top + 8) + 'px';
      popover.style.left = left + 'px';
    }
    popover?.classList.toggle('hidden');
  });

  document.addEventListener('click', () => popover?.classList.add('hidden'));
  popover?.addEventListener('click', (e) => e.stopPropagation());

  function showModal(id: string) {
    const modal = document.getElementById(`modal-${id}`) as HTMLElement | null;
    if (modal) modal.style.display = 'flex';
  }
  function hideModal(modal: HTMLElement) {
    modal.style.display = 'none';
  }

  document.querySelectorAll('.tip-trigger').forEach((btn) => {
    btn.addEventListener('click', () => {
      popover?.classList.add('hidden');
      const id = (btn as HTMLElement).dataset.id;
      if (id) showModal(id);
    });
  });

  document.querySelectorAll<HTMLElement>('.tip-modal').forEach((modal) => {
    modal.addEventListener('click', (e) => {
      if (e.target === modal) hideModal(modal);
    });
    modal.querySelector('.modal-close')?.addEventListener('click', () => {
      hideModal(modal);
    });
  });

  document.querySelectorAll('.copy-addr').forEach((btn) => {
    btn.addEventListener('click', () => {
      const address = (btn as HTMLElement).dataset.address ?? '';
      navigator.clipboard.writeText(address);
      btn.textContent = 'Copied!';
      setTimeout(() => { btn.textContent = 'Copy address'; }, 2000);
    });
  });

  document.querySelector('.open-kofi')?.addEventListener('click', () => {
    window.open('https://ko-fi.com/savyasachi', '_blank');
  });
</script>
