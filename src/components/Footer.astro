---
import { config } from '../data/config';
const fullName = `${config.name.first} ${config.name.last}`;

const links = [
  config.social.github   && { label: 'GitHub',   href: config.social.github },
  config.social.linkedin && { label: 'LinkedIn',  href: config.social.linkedin },
  config.social.email    && { label: 'Email',     href: `mailto:${config.social.email}` },
  { label: 'Resume', href: '/resume.pdf' },
].filter(Boolean) as { label: string; href: string }[];

const kofi = { id: 'kofi', label: 'Ko-fi', url: 'https://ko-fi.com/savyasachi', color: '#FF5E5B' };

const wallets = [
  { id: 'btc', label: 'BTC', address: 'bc1qc0fv4mactnhkpddhn3h7y63ktzemaetw6pa5fe',  color: '#F7931A' },
  { id: 'eth', label: 'ETH', address: '0xe73B6A122E9B41d8a6c979AEBD109f23A85D01f8',   color: '#627EEA' },
  { id: 'ltc', label: 'LTC', address: 'ltc1qng7ax8m8aq0z4dms5z5vxwldyl4wk666xpfj0e', color: '#345D9D' },
];
---

<footer class="border-t border-[var(--color-border)] py-8">
  <div class="max-w-6xl mx-auto px-6 flex flex-col sm:flex-row items-center justify-between gap-4 text-sm" style="color: var(--color-text-muted);">
    <span>&copy; {new Date().getFullYear()} {fullName}</span>
    <div class="flex items-center gap-5 flex-wrap justify-center">
      {links.map((link) => (
        <>
          <a
            href={link.href}
            target={link.href.startsWith('mailto') || link.href.startsWith('/') ? undefined : '_blank'}
            rel={link.href.startsWith('http') ? 'noopener noreferrer' : undefined}
            class="footer-link"
          >
            {link.label}
          </a>
          <span style="color: var(--color-border);">·</span>
        </>
      ))}

      <div>
        <button
          id="tip-jar-btn"
          class="footer-link"
          aria-expanded="false"
          aria-controls="tip-popover"
          style="background: none; border: none; cursor: pointer; font-size: inherit; padding: 0; font-family: inherit;"
        >
          Tip Jar
        </button>

        <div
          id="tip-popover"
          class="hidden p-4 rounded-xl border z-50"
          role="dialog"
          aria-label="Tip options"
          style="position: fixed; background: var(--color-surface); border-color: var(--color-border); width: fit-content; box-shadow: 0 8px 32px rgba(0,0,0,0.4);"
        >
          <p class="text-xs mb-4 leading-relaxed" style="color: var(--color-text-muted);">
            If you found this useful, or just vibing with the stack,
            consider supporting me!
          </p>

          <div class="flex gap-2 items-center justify-center">
            <button
              class="tip-trigger tip-btn-kofi py-1 px-2 rounded-md border flex items-center justify-center gap-2 flex-1"
              data-id={kofi.id}
            >
              <span style="font-size: 1.1rem;">☕</span>
              <span style="font-size: 0.75rem; line-height: 1; font-weight: 700;">{kofi.label}</span>
            </button>

            <button
              class="tip-trigger tip-btn-btc py-1 px-2 rounded-md border flex items-center justify-center gap-2 flex-1"
              data-id="btc"
            >
              <span style="font-size: 1.1rem; color: #F7931A;">₿</span>
              <span style="font-size: 0.75rem; line-height: 1; font-weight: 700;">BTC</span>
            </button>

            <button
              class="tip-trigger tip-btn-eth py-1 px-2 rounded-md border flex items-center justify-center gap-2 flex-1"
              data-id="eth"
            >
              <span style="font-size: 1.1rem; color: #627EEA;">Ξ</span>
              <span style="font-size: 0.75rem; line-height: 1; font-weight: 700;">ETH</span>
            </button>

            <button
              class="tip-trigger tip-btn-ltc py-1 px-2 rounded-md border flex items-center justify-center gap-2 flex-1"
              data-id="ltc"
            >
              <span style="font-size: 1.1rem; color: #345D9D;">Ł</span>
              <span style="font-size: 0.75rem; line-height: 1; font-weight: 700;">LTC</span>
            </button>
          </div>
        </div>
      </div>
    </div>
  </div>
</footer>

<div
  id={`modal-${kofi.id}`}
  class="tip-modal"
  role="dialog"
  aria-modal="true"
  aria-label={`${kofi.label} tip`}
  style="display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; z-index: 50; align-items: center; justify-content: center; padding: 1rem; background: rgba(0,0,0,0.6); backdrop-filter: blur(4px);"
>
  <div
    class="relative rounded-2xl border p-6 flex flex-col items-center gap-4 w-full"
    style="background: var(--color-surface); border-color: var(--color-border); box-shadow: 0 24px 64px rgba(0,0,0,0.5); max-width: 28rem;"
  >
    <button
      class="modal-close absolute top-4 right-4"
      aria-label="Close dialog"
      style="color: var(--color-text-muted); background: none; border: none; cursor: pointer; font-size: 1.1rem; line-height: 1;"
    >
      ✕
    </button>

    <span
      class="text-xs font-bold rounded-md px-3 py-1"
      style={`background:${kofi.color};color:#fff;letter-spacing:0.08em;`}
    >
      {kofi.label}
    </span>

    <img
      src={`https://api.qrserver.com/v1/create-qr-code/?size=180x180&data=${kofi.url}&bgcolor=ffffff&color=000000&margin=8&ecc=H`}
      alt={`${kofi.label} QR code`}
      width="180"
      height="180"
      class="rounded-lg"
    />

    <div class="w-full flex flex-col gap-2">
      <code class="w-full block text-xs text-center break-all" style="color: var(--color-text-muted);">{kofi.url}</code>
      <button
        class="open-kofi w-full py-2 rounded-lg text-sm font-medium"
        style="background: var(--color-accent); color: var(--color-bg);"
      >
        Open Ko-fi →
      </button>
    </div>
  </div>
</div>

{wallets.map((w) => (
  <div
    id={`modal-${w.id}`}
    class="tip-modal"
    role="dialog"
    aria-modal="true"
    aria-label={`${w.label} tip address`}
    style="display: none; position: fixed; top: 0; left: 0; right: 0; bottom: 0; z-index: 50; align-items: center; justify-content: center; padding: 1rem; background: rgba(0,0,0,0.6); backdrop-filter: blur(4px);"
  >
    <div
      class="relative rounded-2xl border p-6 flex flex-col items-center gap-4 w-full"
      style="background: var(--color-surface); border-color: var(--color-border); box-shadow: 0 24px 64px rgba(0,0,0,0.5); max-width: 28rem;"
    >
      <button
        class="modal-close absolute top-4 right-4"
        aria-label="Close dialog"
        style="color: var(--color-text-muted); background: none; border: none; cursor: pointer; font-size: 1.1rem; line-height: 1;"
      >
        ✕
      </button>

      <span
        class="text-xs font-bold rounded-md px-3 py-1"
        style={`background:${w.color};color:#fff;letter-spacing:0.08em;`}
      >
        {w.label}
      </span>

      <img
        src={`https://api.qrserver.com/v1/create-qr-code/?size=180x180&data=${w.address}&bgcolor=ffffff&color=000000&margin=8&ecc=H`}
        alt={`${w.label} QR code`}
        width="180"
        height="180"
        class="rounded-lg"
      />

      <div class="w-full flex flex-col gap-2">
        <code class="w-full block text-xs text-center break-all" style="color: var(--color-text-muted);">{w.address}</code>
        <button
          class="copy-addr w-full py-2 rounded-lg text-sm font-medium"
          style="background: var(--color-accent); color: var(--color-bg);"
          data-address={w.address}
        >
          Copy address
        </button>
      </div>
    </div>
  </div>
))}

<style>
  .footer-link {
    color: var(--color-text-muted);
    transition: color 0.15s;
  }
  .footer-link:hover { color: var(--color-accent); }

  .tip-trigger {
    border-color: var(--color-border);
    color: var(--color-text-muted);
    background: none;
    cursor: pointer;
    font-family: inherit;
    transition: border-color 0.15s, color 0.15s, background 0.15s;
  }
  .tip-btn-kofi:hover { border-color: #FF5E5B; color: #FF5E5B; background: #FF5E5B18; }
  .tip-btn-btc:hover  { border-color: #F7931A; color: #F7931A; background: #F7931A18; }
  .tip-btn-eth:hover  { border-color: #627EEA; color: #627EEA; background: #627EEA18; }
  .tip-btn-ltc:hover  { border-color: #345D9D; color: #345D9D; background: #345D9D18; }

  .open-kofi, .copy-addr {
    transition: opacity 0.15s;
  }
  .open-kofi:hover, .copy-addr:hover { opacity: 0.85; }
  .modal-close {
    transition: color 0.15s;
  }
  .modal-close:hover { color: var(--color-text); }
</style>

<script>
  const tipBtn = document.getElementById('tip-jar-btn');
  const popover = document.getElementById('tip-popover');

  function setPopoverOpen(open: boolean) {
    if (!popover || !tipBtn) return;
    popover.classList.toggle('hidden', !open);
    tipBtn.setAttribute('aria-expanded', open ? 'true' : 'false');
    if (open) {
      const rect = (tipBtn as HTMLElement).getBoundingClientRect();
      const margin = 8;
      const pw = popover.offsetWidth;
      let left = rect.right - pw;
      left = Math.max(margin, Math.min(left, window.innerWidth - pw - margin));
      popover.style.bottom = (window.innerHeight - rect.top + 8) + 'px';
      popover.style.left = left + 'px';
    }
  }

  tipBtn?.addEventListener('click', (e) => {
    e.stopPropagation();
    const isHidden = popover?.classList.contains('hidden');
    setPopoverOpen(Boolean(isHidden));
  });

  document.addEventListener('click', (e) => {
    if (e.target !== tipBtn && !popover?.contains(e.target as Node)) {
      setPopoverOpen(false);
    }
  });

  window.addEventListener('scroll', () => setPopoverOpen(false), { passive: true });

  const focusableSelector = 'button, [href], input, select, textarea, [tabindex]:not([tabindex="-1"])';
  let lastFocused: HTMLElement | null = null;

  function showModal(id: string) {
    const modal = document.getElementById(`modal-${id}`) as HTMLElement | null;
    if (!modal) return;
    lastFocused = document.activeElement as HTMLElement;
    modal.style.display = 'flex';
    const first = modal.querySelector<HTMLElement>(focusableSelector);
    first?.focus();
  }
  function hideModal(modal: HTMLElement) {
    modal.style.display = 'none';
    lastFocused?.focus();
    lastFocused = null;
  }
  function hideAllModals() {
    document.querySelectorAll<HTMLElement>('.tip-modal').forEach((m) => {
      if (m.style.display !== 'none') hideModal(m);
    });
  }
  function openModal(): HTMLElement | null {
    return Array.from(document.querySelectorAll<HTMLElement>('.tip-modal'))
      .find((m) => m.style.display !== 'none') ?? null;
  }

  document.querySelectorAll('.tip-trigger').forEach((btn) => {
    btn.addEventListener('click', () => {
      setPopoverOpen(false);
      const id = (btn as HTMLElement).dataset.id;
      if (id) showModal(id);
    });
  });

  document.querySelectorAll<HTMLElement>('.tip-modal').forEach((modal) => {
    modal.addEventListener('click', (e) => {
      if (e.target === modal) hideModal(modal);
    });
    modal.querySelector('.modal-close')?.addEventListener('click', () => {
      hideModal(modal);
    });
  });

  document.addEventListener('keydown', (e) => {
    if (e.key === 'Escape') {
      if (!popover?.classList.contains('hidden')) {
        setPopoverOpen(false);
        (tipBtn as HTMLElement | null)?.focus();
        return;
      }
      const open = openModal();
      if (open) hideModal(open);
      return;
    }

    if (e.key === 'Tab') {
      const open = openModal();
      if (!open) return;
      const focusable = Array.from(open.querySelectorAll<HTMLElement>(focusableSelector));
      if (focusable.length === 0) return;
      const first = focusable[0];
      const last = focusable[focusable.length - 1];
      if (e.shiftKey && document.activeElement === first) {
        e.preventDefault();
        last.focus();
      } else if (!e.shiftKey && document.activeElement === last) {
        e.preventDefault();
        first.focus();
      }
    }
  });

  document.querySelectorAll('.copy-addr').forEach((btn) => {
    btn.addEventListener('click', () => {
      const address = (btn as HTMLElement).dataset.address ?? '';
      navigator.clipboard.writeText(address);
      btn.textContent = 'Copied!';
      setTimeout(() => { btn.textContent = 'Copy address'; }, 2000);
    });
  });

  document.querySelector('.open-kofi')?.addEventListener('click', () => {
    window.open('https://ko-fi.com/savyasachi', '_blank');
  });
</script>
