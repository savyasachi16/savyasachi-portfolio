---
import type { SkillCategory } from '../../data/skills';

interface Props {
  category: SkillCategory;
}

const { category } = Astro.props;

const ICON_SLUG: Record<string, string> = {
  'Java': 'openjdk',
  'Clojure': 'clojure',
  'Ruby': 'ruby',
  'Python': 'python',
  'Nginx': 'nginx',
  'Apache Kafka': 'apachekafka',
  'Grails': 'grails',
  'Node.js': 'nodedotjs',
  'PostgreSQL': 'postgresql',
  'MongoDB': 'mongodb',
  'Redis': 'redis',
  'Claude Code': 'claude',
  'Docker': 'docker',
  'Kubernetes': 'kubernetes',
  'Argo': 'argo',
  'Splunk': 'splunk',
  'AWS': 'amazonwebservices',
  'Sumo Logic': 'sumologic',
  'Bash': 'gnubash',
  'Git': 'git',
  'JMeter': 'apachejmeter',
  'Jetty': 'eclipsejetty',
};
---

<div>
  <h3
    class="text-xs font-semibold uppercase tracking-widest mb-3"
    style="color: var(--color-text-muted);"
  >
    {category.label}
  </h3>
  <div class="flex flex-wrap gap-2">
    {category.skills.map((skill) => {
      const slug = ICON_SLUG[skill];
      return (
        <span
          class="skill-pill inline-flex items-center gap-1.5 px-3 py-1 text-sm rounded-full border cursor-default"
          style="border-color: var(--color-border); color: var(--color-text-muted); background: color-mix(in srgb, var(--color-accent-glow) 40%, transparent);"
        >
          {slug && (
            <img
              src={`https://cdn.simpleicons.org/${slug}/8a9ab5`}
              alt=""
              width="13"
              height="13"
              loading="lazy"
              aria-hidden="true"
            />
          )}
          {skill}
        </span>
      );
    })}
  </div>
</div>

<style>
  .skill-pill {
    transition: border-color 0.15s;
  }
  .skill-pill:hover {
    border-color: var(--color-accent);
  }
</style>
