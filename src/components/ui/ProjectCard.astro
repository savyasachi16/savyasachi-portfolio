---
import type { Project } from '../../data/projects';

interface Props {
  project: Project;
}

const { project } = Astro.props;
const color = project.color ?? 'var(--color-accent)';
const glow = project.color ? `${project.color}22` : 'var(--color-accent-glow)';

const ICON_SLUG: Record<string, string> = {
  'Astro': 'astro',
  'Tailwind CSS': 'tailwindcss',
  'TypeScript': 'typescript',
  'Claude Agent SDK': 'anthropic',
  'MCP': 'anthropic',
  'Shell': 'gnubash',
  'Bash': 'gnubash',
  'Python': 'python',
  'React': 'react',
  'SQLite': 'sqlite',
  'Recharts': 'chartdotjs',
};
---

<article
  class="project-card flex flex-col gap-4 p-6 rounded-xl border backdrop-blur-sm"
  style={`--card-color: ${color}; --card-glow: ${glow};`}
>
  <div class="flex items-start justify-between gap-4">
    <h3 class="font-semibold" style="font-family: 'Syne', sans-serif; color: var(--card-color);">
      {project.title}
    </h3>
    <a
      href={project.githubUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="project-card-github shrink-0 text-xs"
      aria-label={`GitHub: ${project.title}`}
    >
      GitHub ↗
    </a>
  </div>

  <p class="text-sm leading-relaxed" style="color: var(--color-text-muted);">{project.description}</p>

  <div class="flex flex-wrap gap-2 mt-auto">
    {project.techStack.map((tech) => {
      const slug = ICON_SLUG[tech];
      return (
        <span
          class="tech-pill inline-flex items-center gap-1.5 px-2.5 py-0.5 text-xs rounded-full border"
          style="border-color: var(--color-border); color: var(--color-text-muted);"
        >
          {slug && (
            <img
              src={`https://cdn.simpleicons.org/${slug}`}
              alt=""
              width="11"
              height="11"
              loading="lazy"
              aria-hidden="true"
            />
          )}
          {tech}
        </span>
      );
    })}
  </div>

  {project.liveUrl && (
    <a
      href={project.liveUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="text-xs hover:underline"
      style="color: var(--card-color);"
    >
      Live site ↗
    </a>
  )}
</article>

<style>
  .project-card {
    background: color-mix(in srgb, var(--color-surface) 70%, transparent);
    border-color: var(--color-border);
    box-shadow: 0 0 0 transparent;
    transition: box-shadow 0.2s, border-color 0.2s, transform 0.2s;
  }
  .project-card:hover {
    border-color: var(--card-color);
    box-shadow: 0 8px 32px var(--card-glow);
    transform: translateY(-3px);
  }
  .project-card-github {
    color: var(--color-text-muted);
    transition: color 0.15s;
  }
  .project-card-github:hover {
    color: var(--color-accent);
  }
</style>
