---
import type { Project } from '../../data/projects';

interface Props {
  project: Project;
}

const { project } = Astro.props;
const color = project.color ?? 'var(--color-accent)';
const glow = project.color ? `${project.color}22` : 'var(--color-accent-glow)';

const ICON_SLUG: Record<string, string> = {
  'Astro': 'astro',
  'Tailwind CSS': 'tailwindcss',
  'TypeScript': 'typescript',
  'Claude Agent SDK': 'anthropic',
  'MCP': 'anthropic',
  'Shell': 'gnubash',
  'Bash': 'gnubash',
  'Python': 'python',
  'Rust': 'rust',
  'React': 'react',
  'SQLite': 'sqlite',
  'Recharts': 'chartdotjs',
  'tmux': 'tmux',
  'Ollama': 'ollama',
};

const MONOGRAM_ICON: Record<string, string> = {
  'Plaid': 'P',
  'Goose': 'G',
  'Mem0': 'M',
  'Qwen 2.5': 'Q',
};
---

<article
  class="project-card relative flex flex-col gap-4 p-6 rounded-xl border backdrop-blur-sm"
  style={`--card-color: ${color}; --card-glow: ${glow};`}
>
  <a
    href={project.githubUrl}
    target="_blank"
    rel="noopener noreferrer"
    class="project-card-stretched"
    aria-label={`GitHub: ${project.title}`}
  ></a>

  <div class="project-card-content flex items-start justify-between gap-4">
    <h3 class="font-semibold" style="font-family: 'Syne', sans-serif; color: var(--card-color);">
      {project.title}
    </h3>
    <a
      href={project.githubUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="project-card-github shrink-0 text-xs"
      aria-label={`GitHub: ${project.title}`}
    >
      GitHub ↗
    </a>
  </div>

  <p class="project-card-content text-sm leading-relaxed" style="color: var(--color-text-muted);">{project.description}</p>

  <div class="project-card-content flex flex-wrap gap-2 mt-auto">
    {project.techStack.map((tech) => {
      const slug = ICON_SLUG[tech];
      const monogram = MONOGRAM_ICON[tech];
      return (
        <span
          class="tech-pill inline-flex items-center gap-1.5 px-2.5 py-0.5 text-xs rounded-full border"
          style="border-color: var(--color-border); color: var(--color-text-muted);"
        >
          {slug && (
            <img
              src={`https://cdn.simpleicons.org/${slug}`}
              alt=""
              width="11"
              height="11"
              loading="lazy"
              aria-hidden="true"
            />
          )}
          {!slug && monogram && (
            <span
              class="tech-monogram inline-flex h-[11px] w-[11px] items-center justify-center rounded-full text-[8px] font-semibold leading-none"
              aria-hidden="true"
            >
              {monogram}
            </span>
          )}
          {tech}
        </span>
      );
    })}
  </div>

  {project.liveUrl && (
    <a
      href={project.liveUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="project-card-live text-xs hover:underline"
      style="color: var(--card-color);"
    >
      Live site ↗
    </a>
  )}
</article>

<style>
  .project-card {
    background: color-mix(in srgb, var(--color-surface) 70%, transparent);
    border-color: var(--color-border);
    box-shadow: 0 0 0 transparent;
    cursor: pointer;
    transition: box-shadow 0.2s, border-color 0.2s, transform 0.2s;
  }
  .project-card-stretched {
    position: absolute;
    inset: 0;
    z-index: 0;
    border-radius: inherit;
  }
  .project-card-stretched:focus-visible {
    outline: 2px solid var(--card-color);
    outline-offset: 3px;
  }
  .project-card-content,
  .project-card-github,
  .project-card-live {
    position: relative;
    z-index: 1;
  }
  .project-card-content {
    pointer-events: none;
  }
  .project-card-github,
  .project-card-live {
    pointer-events: auto;
  }
  .project-card:hover {
    border-color: var(--card-color);
    box-shadow: 0 8px 32px var(--card-glow);
    transform: translateY(-3px);
  }
  .project-card-github {
    color: var(--color-text-muted);
    transition: color 0.15s;
  }
  .project-card-github:hover {
    color: var(--color-accent);
  }
  .tech-monogram {
    background: color-mix(in srgb, var(--card-color) 18%, transparent);
    color: var(--card-color);
  }
</style>
