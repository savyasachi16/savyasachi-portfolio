---
import type { Project } from '../../data/projects';

interface Props {
  project: Project;
}

const { project } = Astro.props;
const color = project.color ?? 'var(--color-accent)';
const glow = project.color ? `${project.color}22` : 'var(--color-accent-glow)';
---

<article
  class="flex flex-col gap-4 p-6 rounded-xl border backdrop-blur-sm transition-all duration-200 hover:shadow-lg"
  style={`background: color-mix(in srgb, var(--color-surface) 70%, transparent); border-color: var(--color-border); box-shadow: 0 0 0 transparent; --card-color: ${color}; --card-glow: ${glow};`}
  onmouseenter={`this.style.boxShadow='0 8px 32px ${glow}'; this.style.borderColor='${color}'`}
  onmouseleave="this.style.boxShadow='0 0 0 transparent'; this.style.borderColor='var(--color-border)'"
>
  <div class="flex items-start justify-between gap-4">
    <h3 class="font-semibold" style="font-family: 'Syne', sans-serif; color: var(--card-color);">
      {project.title}
    </h3>
    <a
      href={project.githubUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="shrink-0 text-xs transition-colors hover:text-[var(--color-accent)]"
      style="color: var(--color-text-muted);"
      aria-label={`GitHub: ${project.title}`}
    >
      GitHub ↗
    </a>
  </div>

  <p class="text-sm leading-relaxed" style="color: var(--color-text-muted);">{project.description}</p>

  <div class="flex flex-wrap gap-2 mt-auto">
    {project.techStack.map((tech) => (
      <span
        class="px-2.5 py-0.5 text-xs rounded-full border transition-colors"
        style="border-color: var(--color-border); color: var(--color-text-muted);"
      >
        {tech}
      </span>
    ))}
  </div>

  {project.liveUrl && (
    <a
      href={project.liveUrl}
      target="_blank"
      rel="noopener noreferrer"
      class="text-xs hover:underline"
      style="color: var(--card-color);"
    >
      Live site ↗
    </a>
  )}
</article>
