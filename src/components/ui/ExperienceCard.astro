---
import type { Experience } from '../../data/experience';

interface Props {
  experience: Experience;
}

const { experience } = Astro.props;

const COMPANY_SLUG: Record<string, string> = {
  'PayPal': 'paypal',
  'Qualcomm': 'qualcomm',
  'Accenture': 'accenture',
};
const COMPANY_LOGO: Record<string, string> = {
  'Stockpile Investments': '/logos/stockpile.png',
  'NortonLifeLock': '/logos/norton.png',
};
const slug = COMPANY_SLUG[experience.company];
const localLogo = COMPANY_LOGO[experience.company];
const logoSrc = slug
  ? `https://cdn.simpleicons.org/${slug}/8a9ab5`
  : localLogo;
---

<div class="exp-root relative pl-6 border-l-2">
  <div class="mb-4">
    <div class="inline-flex items-center gap-2.5">
      {logoSrc && (
        <img
          src={logoSrc}
          alt=""
          width="18"
          height="18"
          loading="lazy"
          aria-hidden="true"
          class={localLogo ? 'exp-logo-muted' : ''}
        />
      )}
      {experience.companyUrl ? (
        <a
          href={experience.companyUrl}
          target="_blank"
          rel="noopener noreferrer"
          class="exp-company-link text-lg font-semibold"
          style="font-family: 'Syne', sans-serif;"
        >
          {experience.company}
        </a>
      ) : (
        <span class="text-lg font-semibold" style="font-family: 'Syne', sans-serif; color: var(--color-text);">
          {experience.company}
        </span>
      )}
    </div>
    <span class="block text-sm" style="color: var(--color-text-muted);">{experience.location}</span>
  </div>

  <div class="flex flex-col gap-6">
    {experience.roles.map((role) => {
      const hasAccomplishments = role.accomplishments.length > 0;
      return (
        <div class="relative">
          <div
            class="absolute -left-[1.875rem] top-2 w-2.5 h-2.5 rounded-full"
            style="background: var(--color-accent); box-shadow: 0 0 0 3px var(--color-bg);"
          />

          {hasAccomplishments ? (
            <details class="group">
              <summary class="exp-summary flex items-center justify-between gap-4 cursor-pointer list-none select-none rounded-lg px-3 py-2 -mx-3">
                <div>
                  <span class="font-medium block">{role.title}</span>
                  <span class="text-sm" style="color: var(--color-text-muted);">{role.startDate} – {role.endDate}</span>
                </div>
                <svg
                  class="shrink-0 transition-transform duration-200 group-open:rotate-180"
                  style="color: var(--color-text-muted);"
                  xmlns="http://www.w3.org/2000/svg"
                  width="20"
                  height="20"
                  viewBox="0 0 24 24"
                  fill="none"
                  stroke="currentColor"
                  stroke-width="2"
                  stroke-linecap="round"
                  stroke-linejoin="round"
                >
                  <path d="m6 9 6 6 6-6"/>
                </svg>
              </summary>

              <ul class="flex flex-col gap-2 mt-3 pl-1">
                {role.accomplishments.map((item) => (
                  <li class="text-base leading-relaxed pl-4 relative exp-bullet">
                    <span class="absolute left-0 exp-bullet-dot">•</span>
                    {item}
                  </li>
                ))}
              </ul>
            </details>
          ) : (
            <div class="flex items-center gap-4 px-3 py-2 -mx-3">
              <div>
                <span class="font-medium block" style="color: var(--color-text);">{role.title}</span>
                <span class="text-sm" style="color: var(--color-text-muted);">{role.startDate} – {role.endDate}</span>
              </div>
            </div>
          )}
        </div>
      );
    })}
  </div>
</div>

<style>
  .exp-root {
    border-color: color-mix(in srgb, var(--color-accent) 30%, transparent);
  }
  .exp-company-link {
    color: var(--color-text);
    transition: color 0.15s;
  }
  .exp-company-link:hover {
    color: var(--color-accent);
  }
  .exp-summary {
    color: var(--color-text);
    transition: background 0.15s;
  }
  .exp-summary:hover {
    background: color-mix(in srgb, var(--color-accent-glow) 60%, transparent);
  }
  .exp-bullet {
    color: color-mix(in srgb, var(--color-text) 80%, var(--color-text-muted));
  }
  .exp-bullet-dot {
    color: var(--color-accent);
    font-weight: 700;
  }
  .exp-logo-muted {
    filter: grayscale(1) brightness(1.2) opacity(0.7);
  }
</style>
