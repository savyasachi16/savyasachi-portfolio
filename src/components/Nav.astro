---
import { config } from '../data/config';
const fullName = `${config.name.first} ${config.name.last}`;
---

<header class="sticky top-0 z-50 border-b border-[var(--color-border)] bg-[var(--color-bg)]/90 backdrop-blur-sm transition-colors duration-200">
  <nav class="max-w-6xl mx-auto px-6 h-14 flex items-center justify-between">
    <a href="/" class="nav-brand text-sm font-semibold tracking-wide" style="font-family: 'Syne', sans-serif;">
      {fullName}
    </a>

    <div class="flex items-center gap-3">
      <ul class="hidden md:flex items-center gap-6">
        <li><a href="#experience" class="nav-link text-sm">Experience</a></li>
        <li><a href="#projects"   class="nav-link text-sm">Projects</a></li>
        <li><a href="#skills"     class="nav-link text-sm">Skills</a></li>
        <li><a href="#education"  class="nav-link text-sm">Education</a></li>
        <li><a href="#beyond"     class="nav-link text-sm">Beyond</a></li>
        <li><a href="#contact"    class="nav-link text-sm">Contact</a></li>
      </ul>

      <button
        id="theme-toggle"
        aria-label="Toggle theme"
        class="theme-btn w-8 h-8 flex items-center justify-center rounded-lg border"
      >
        <svg id="icon-sun" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <circle cx="12" cy="12" r="4"/>
          <line x1="12" y1="2"  x2="12" y2="5"/>
          <line x1="12" y1="19" x2="12" y2="22"/>
          <line x1="4.22" y1="4.22" x2="6.34" y2="6.34"/>
          <line x1="17.66" y1="17.66" x2="19.78" y2="19.78"/>
          <line x1="2"  y1="12" x2="5"  y2="12"/>
          <line x1="19" y1="12" x2="22" y2="12"/>
          <line x1="4.22" y1="19.78" x2="6.34" y2="17.66"/>
          <line x1="17.66" y1="6.34" x2="19.78" y2="4.22"/>
        </svg>
        <svg id="icon-moon" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z"/>
        </svg>
        <svg id="icon-system" xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden">
          <rect x="2" y="3" width="20" height="14" rx="2"/>
          <line x1="8" y1="21" x2="16" y2="21"/>
          <line x1="12" y1="17" x2="12" y2="21"/>
        </svg>
      </button>

      <button
        id="menu-toggle"
        aria-label="Toggle menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
        class="menu-btn md:hidden w-8 h-8 flex items-center justify-center rounded-lg border"
      >
        <svg id="icon-menu" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
          <line x1="3" y1="6"  x2="21" y2="6"/>
          <line x1="3" y1="12" x2="21" y2="12"/>
          <line x1="3" y1="18" x2="21" y2="18"/>
        </svg>
        <svg id="icon-close" xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="hidden">
          <line x1="18" y1="6" x2="6" y2="18"/>
          <line x1="6" y1="6" x2="18" y2="18"/>
        </svg>
      </button>
    </div>
  </nav>

  <div
    id="mobile-menu"
    class="hidden md:hidden border-t px-6 py-4"
    style="border-color: var(--color-border); background: var(--color-bg);"
  >
    <ul class="flex flex-col gap-4">
      <li><a href="#experience" class="mobile-nav-link nav-link text-sm">Experience</a></li>
      <li><a href="#projects"   class="mobile-nav-link nav-link text-sm">Projects</a></li>
      <li><a href="#skills"     class="mobile-nav-link nav-link text-sm">Skills</a></li>
      <li><a href="#education"  class="mobile-nav-link nav-link text-sm">Education</a></li>
      <li><a href="#beyond"     class="mobile-nav-link nav-link text-sm">Beyond</a></li>
      <li><a href="#contact"    class="mobile-nav-link nav-link text-sm">Contact</a></li>
    </ul>
  </div>
</header>

<style>
  .nav-brand {
    color: var(--color-text);
    transition: color 0.15s;
  }
  .nav-brand:hover { color: var(--color-accent); }
  .nav-link {
    color: var(--color-text-muted);
    transition: color 0.15s;
  }
  .nav-link:hover { color: var(--color-text); }
  .theme-btn, .menu-btn {
    border-color: var(--color-border);
    color: var(--color-text-muted);
    transition: border-color 0.2s, color 0.2s, transform 0.2s;
  }
  .theme-btn {
    background: color-mix(in srgb, var(--color-accent-glow) 50%, transparent);
  }
  .theme-btn:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
    transform: scale(1.1);
  }
  .menu-btn:hover { color: var(--color-text); }
</style>

<script>
  function initTheme() {
    const btn    = document.getElementById('theme-toggle');
    const sun    = document.getElementById('icon-sun');
    const moon   = document.getElementById('icon-moon');
    const system = document.getElementById('icon-system');

    function applyTheme(theme: string) {
      document.documentElement.setAttribute('data-theme', theme);
    }

    function updateIcon(mode: string) {
      sun?.classList.toggle('hidden',    mode !== 'dark');
      moon?.classList.toggle('hidden',   mode !== 'light');
      system?.classList.toggle('hidden', mode !== 'system');
    }

    function getSystemTheme() {
      return window.matchMedia('(prefers-color-scheme: light)').matches ? 'light' : 'dark';
    }

    const stored = localStorage.getItem('themeMode') ?? 'system';
    applyTheme(stored === 'system' ? getSystemTheme() : stored);
    updateIcon(stored);

    window.matchMedia('(prefers-color-scheme: light)').addEventListener('change', () => {
      if ((localStorage.getItem('themeMode') ?? 'system') === 'system') {
        applyTheme(getSystemTheme());
      }
    });

    btn?.addEventListener('click', () => {
      const current = localStorage.getItem('themeMode') ?? 'system';
      const next = current === 'dark' ? 'light' : current === 'light' ? 'system' : 'dark';
      localStorage.setItem('themeMode', next);
      applyTheme(next === 'system' ? getSystemTheme() : next);
      updateIcon(next);
    });
  }

  function initMobileMenu() {
    const toggle   = document.getElementById('menu-toggle');
    const menu     = document.getElementById('mobile-menu');
    const iconMenu  = document.getElementById('icon-menu');
    const iconClose = document.getElementById('icon-close');

    function setOpen(open: boolean) {
      menu?.classList.toggle('hidden', !open);
      iconMenu?.classList.toggle('hidden', open);
      iconClose?.classList.toggle('hidden', !open);
      toggle?.setAttribute('aria-expanded', open ? 'true' : 'false');
    }

    toggle?.addEventListener('click', () => {
      const open = !menu?.classList.contains('hidden');
      setOpen(!open);
    });

    document.querySelectorAll('.mobile-nav-link').forEach(link => {
      link.addEventListener('click', () => setOpen(false));
    });

    document.addEventListener('click', (e) => {
      if (!menu?.classList.contains('hidden') &&
          !menu?.contains(e.target as Node) &&
          e.target !== toggle) {
        setOpen(false);
      }
    });

    document.addEventListener('keydown', (e) => {
      if (e.key === 'Escape' && !menu?.classList.contains('hidden')) {
        setOpen(false);
      }
    });
  }

  function initNavHighlight() {
    const sections = document.querySelectorAll<HTMLElement>('section[id]');
    const navLinks = document.querySelectorAll<HTMLAnchorElement>('a[href^="#"]');

    const observer = new IntersectionObserver((entries) => {
      entries.forEach(entry => {
        if (entry.isIntersecting) {
          navLinks.forEach(link => {
            const active = link.getAttribute('href') === `#${entry.target.id}`;
            link.style.color = active ? 'var(--color-text)' : '';
          });
        }
      });
    }, { rootMargin: '-40% 0px -55% 0px' });

    sections.forEach(s => observer.observe(s));
  }

  initTheme();
  initMobileMenu();
  initNavHighlight();
</script>
